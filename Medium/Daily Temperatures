class Solution {
public:
    vector<int> dailyTemperatures(vector<int>& temperatures) {
        stack<int>st;
        vector<int>res(temperatures.size(),0);
        for(int x = 0; x<temperatures.size(); x++){
            while(!st.empty() && temperatures[st.top()]<temperatures[x]){
                res[st.top()] = x-st.top();
                st.pop();
            }
            st.push(x);
        }
        return res;
    } 
};
