/*You have N sticks and the i-th of them has length Li. You're going to choose 4 sticks and create a square out of them (a rectangle with four sides of equal length). It is allowed to shorten the sticks to make them equal.

What is the maximum possible area of a square you will get?

Input
The first line contains an integer N (1≤N≤2000) — the number of sticks.

The second line contains N integers L1,L2,…,LN (1≤Li≤109) — lengths of sticks.

Output
Print one integer — the maximum possible area of a square. If it's impossible to get a square, print 0 instead.*/

#include <bits/stdc++.h>
using namespace std;
 
 
int main(){
	ios::sync_with_stdio(0);
	cin.tie(0);
	int tc;
	scanf("%i",&tc);
	if(tc<4){
		cout<<0;
		return 0;
	}
	vector<long long>sticks;
	while(tc--){
		long long stick;
		scanf("%lld", &stick);
		sticks.push_back(stick);
	}
	sort(sticks.begin(),sticks.end());
	long long n = sticks.size();
	cout<<sticks[n-4]*sticks[n-4];
	return 0;
}
