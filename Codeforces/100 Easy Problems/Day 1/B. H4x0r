/*Hackers use their own language not meant to be understood by normal people. They replace some characters with digits that look similar, for example 'i' is replaced with '1' and thus "win" becomes "w1n". That's an unbreakable cipher, right?

Here's a full list of changes:

a -> 4
i -> 1
e -> 3
o -> 0
s -> 5
Do you have what it takes to become a hacker? Given a string with lowercase English characters, apply changes according to the list.

Input
The only line of the input contains a string s consisting of lowercase English letters ('a' - 'z'). It's guarateed that 1≤|s|≤106, where |s| denotes the length of s.

Output
Print the modified string.*/

#include <bits/stdc++.h>
using namespace std;
 
 
int main(){
	ios::sync_with_stdio(0);
	cin.tie(0);
	string word;
	cin>>word;
	unordered_map<char,char>m;
	m['a'] = '4';
	m['i'] = '1';
	m['e'] = '3';
	m['o'] = '0';
	m['s'] = '5';
	for(int x = 0; x<word.size(); x++){
		if(m.find(word[x])!=m.end()){
			word[x] = m[word[x]];
		}
	}
	cout<<word;
	return 0;
}
