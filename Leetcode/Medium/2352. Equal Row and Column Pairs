/*
Time Complexity: O(N)
Space Complexity: O(N)
*/

class Solution {
public:
    int equalPairs(vector<vector<int>>& grid) {
        map<vector<int>,int> rows;
        int res = 0;
        for(vector<int>i : grid) rows[i]++;
        for(int x = 0; x<grid.size(); x++){
            vector<int>column;
            for(int i = 0; i <grid[x].size(); i++){
                column.push_back(grid[i][x]);
            }
            res+= rows[column];
        }
        return res;
    }
};
