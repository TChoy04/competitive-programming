class Solution {
public:
    int numberOfGoodSubarraySplits(vector<int>& nums) {
        long res = 1;
        int count = 1;
        int i = 0;
        while(nums[i]!=1){
            i++;
            if(i==nums.size()) return 0;
        }
        for(int x = i; x<nums.size(); x++){
            if(nums[x]==1){ 
                res*= count;
                res%=1000000007;
                count = 1;
            }else count++;
        }
        return res;
    }
};
