Time Complexity: O(N)
Space Complexity: O(1)



class Solution {
public:
    int compress(vector<char>& chars) {
        int L = 0;
        int R = 0;
        char curr = chars[0];
        int count = 1;
        int length = 0;
        while(R<chars.size()){
            if((R == chars.size()-1) || chars[R+1]!=curr ){
                chars[L++] = curr;
                length++;
                if(R!=chars.size()-1) curr = chars[R+1];
                if(count>1){
                    string temp = to_string(count);
                    for(int x = 0; x<temp.size(); x++){
                        chars[L++] = temp[x];
                        length++;
                    }
                }
                count = 0;
            }
            count++;
            R++;
        }
        return length;
    }
};
