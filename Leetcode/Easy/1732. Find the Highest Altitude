/*
Time Complexity: O(N)
Space Complexity: O(1)
Trivial problem to be honest. Should be self explanatory. 
*/

class Solution {
public:
    int largestAltitude(vector<int>& gain) {
        int count = 0;
        int res = 0;
        for(int i : gain){
            count+=i;
            res = max(res,count);
        }
        return res;
    }
};
